generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  tasks     Task[]
  notifications Notification[]
  profile   Profile?
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  dueDate     DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  sharedWith  SharedTask[]
  comments    Comment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("tasks")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@map("notifications")
}

model SharedTask {
  id         String   @id @default(uuid())
  taskId     String
  sharedBy   String
  sharedWith String
  permission String   @default("VIEW")
  createdAt  DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@unique([taskId, sharedWith])
  @@index([sharedWith])
  @@index([sharedBy])
  @@map("shared_tasks")
}

model Profile {
  id         String   @id @default(uuid())
  userId     String   @unique
  avatar     String?
  bio        String?
  phone      String?
  updatedAt  DateTime @updatedAt
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("profiles")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  
  @@index([taskId])
  @@index([userId])
  @@map("comments")
}
